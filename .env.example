FRONTEND_URL=http://localhost:9000

# Sanctum & CORS
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:9000,127.0.0.1,127.0.0.1:8000,frontend,backend,plataforma_frontend

# OAuth Social Login
