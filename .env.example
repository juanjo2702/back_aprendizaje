# Backend Environment Variables (Development)
# Copy to .env and adjust as needed

# Application Environment
APP_NAME="Plataforma de Aprendizaje (Backend)"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=cjZM,|>.2NjKJ%6?UpjNP7R@x@Bh1t

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=plataforma_v2
DB_USERNAME=root
DB_PASSWORD=root

# Session & Cache
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# URLs (important for CORS and API calls)
