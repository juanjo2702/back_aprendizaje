# ──────────────────────────────────────────────────────────────────
#  PRODUCTION Environment Configuration
#  WARNING: Do not commit sensitive data to version control
# ──────────────────────────────────────────────────────────────────
APP_NAME="Plataforma de Aprendizaje"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tudominio.com
APP_TIMEZONE=UTC

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=plataforma_v2_prod
DB_USERNAME=usuario_seguro
DB_PASSWORD=contraseña_fuerte_y_larga

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.tudominio.com

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=contraseña_redis
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=tu_usuario
MAIL_PASSWORD=tu_contraseña
MAIL_FROM_ADDRESS="no-reply@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

SANCTUM_STATEFUL_DOMAINS=tudominio.com,www.tudominio.com
FRONTEND_URL=https://tudominio.com

# Security
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS="${APP_URL},${FRONTEND_URL}"

# Performance
OPCACHE_ENABLE=1

# Application specific
GAMIFICATION_ENABLED=true
MAX_GAME_SCORE=1000
MIN_CERTIFICATE_SCORE=70

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"
VITE_APP_ENV="${APP_ENV}"