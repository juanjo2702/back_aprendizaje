# Production Environment Variables for Backend
# Copy to .env and adjust as needed

# Application Environment
APP_NAME="Plataforma de Aprendizaje (Production)"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
APP_KEY=base64:generate-your-own-key-with-artisan-key-generate

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=plataforma_production
DB_USERNAME=root
DB_PASSWORD=secure_password

# Session & Cache
SESSION_DRIVER=database
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# URLs (important for CORS and API calls)
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Sanctum & CORS
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,api.yourdomain.com

# Redis (if using)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Plataforma de Aprendizaje"
